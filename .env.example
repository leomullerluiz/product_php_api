APP_NAME=product_php_api
APP_ENV=local
JWT_SECRET=change-me-to-a-random-secret-with-at-least-32-chars
JWT_TTL_SECONDS=3600
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SENTRY_DSN=https://seu-dsn-do-sentry
PRODUCT_API_BASE_URL=http://localhost:8080
PRODUCT_API_TEST_TOKEN=

DATABASE_URL=postgres://product_php_api:product_php_api@127.0.0.1:5433/product_php_api_db
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=product_php_api_db
DB_USERNAME=product_php_api
DB_PASSWORD=product_php_api
DB_SSLMODE=disable
