{
  "name": "leomuniz/product-php-api",
  "description": "API RESTful para gerenciamento de produtos em PHP.",
  "license": "MIT",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "firebase/php-jwt": "^7.1",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "classmap": [
      "api/core",
      "api/controller",
      "api/model",
      "api/service"
    ]
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t . index.php"
  }
}
